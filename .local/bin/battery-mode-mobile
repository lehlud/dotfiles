#!/usr/bin/env bash
set -euo pipefail

BAT="${BAT:-/sys/class/power_supply/BAT0}"
START=85
END=92

require_file() {
  local path="$1"
  [[ -e "$path" ]] || {
    printf 'Error: missing file: %s\n' "$path" >&2
    exit 1
  }
}

require_file "$BAT/charge_control_start_threshold"
require_file "$BAT/charge_control_end_threshold"
require_file "$BAT/charge_behaviour"

echo "Requesting sudo permission..."
sudo -v

echo "Setting mobile battery mode..."
sudo bash -c "printf '%s\n' 'auto' > '$BAT/charge_behaviour'"
sudo bash -c "printf '%s\n' '$END' > '$BAT/charge_control_end_threshold'"
sudo bash -c "printf '%s\n' '$START' > '$BAT/charge_control_start_threshold'"

echo
echo "Current battery settings:"
printf 'charge_behaviour: '
cat "$BAT/charge_behaviour"
printf 'start threshold:  '
cat "$BAT/charge_control_start_threshold"
printf 'end threshold:    '
cat "$BAT/charge_control_end_threshold"
