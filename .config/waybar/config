{
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock", "custom/lock"],
    "modules-right": ["custom/spotify", "custom/ram", "custom/cpu", "pulseaudio", "custom/brightness", "battery", "tray"],

    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ´çź",
        "format-ethernet": "{ifname} ´âü",
        "format-disconnected": "´âü", 
        "max-length": 50,
        "on-click": "kitty -e 'nmtui'"
    },

    "tray": {
        "icon-size": 15,
        "spacing": 2
    },

    "clock": {
        // "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // "format-alt": "{:%Y-%m-%d}",
		"on-click": "gnome-calendar"
    },

    "pulseaudio": {
        "format": "{volume}% {icon} ",
        "format-bluetooth": "{volume}% {icon} ´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon} ´Őö {format_source}",
        "format-muted": "0% {icon} ",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´Çą",
            "headset": "´Çą",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },
    
	"custom/lock": {
		"format": "´Çú ",
		"on-click": "hyprlock"
	},

    "battery": {
        	"states": {
            		"warning": 30,
            		"critical": 15
        	},
            "interval": 3,
        	"format": "{capacity}% {icon}",
        	"format-charging": "{capacity}% ´âž ",
        	"format-plugged": "{capacity}% ´çŽ ",
        	"format-alt": "{time} {icon}",
        	"format-full": "{capacity}% ´ëÇ ",
        	"format-icons": ["´ëâ ", "´ëé ", "´ëü "]
	},

    "custom/ram": {
        "return-type": "text",
        "exec": "~/.config/waybar/ram.sh"
    },

    "custom/cpu": {
        "return-type": "text",
        "exec": "~/.config/waybar/cpu.sh"
    },

    // "custom/battery": {
    //     "return-type": "text",
    //     "exec": "~/.config/waybar/battery.sh"
    // },

    "custom/brightness": {
        "return-type": "text",
        "exec": "~/.config/waybar/brightness.sh",
        "on-click": "light -S 0"
    },

    "custom/spotify": {
        "return-type": "json",
        "exec": "~/.config/waybar/media.py --player spotify",
        "on-click": "playerctl --player spotify play-pause",
        "on-scroll-up": "playerctl --player spotify next",
        "on-scroll-down": "playerctl --player spotify previous",
        "escape": true
    }
}
